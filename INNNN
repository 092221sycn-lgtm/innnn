<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SOONIN-UNIVERS</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', sans-serif;
            background: #ffffff;
            color: #000000;
        }

        /* Header & Navigation */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 30px 60px;
            border-bottom: 1px solid #e0e0e0;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            letter-spacing: 2px;
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 50px;
        }

        nav a {
            text-decoration: none;
            color: #000000;
            font-size: 16px;
            font-weight: 500;
            transition: opacity 0.3s;
        }

        nav a:hover {
            opacity: 0.7;
        }

        /* Hero Section */
        .hero {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 100px 60px;
            min-height: 600px;
            position: relative;
        }

        .hero-content {
            flex: 1;
            max-width: 800px;
        }

        .hero-logo {
            width: 250px;
            height: 200px;
            margin-bottom: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .hero-logo svg {
            width: 100%;
            height: 100%;
        }

        .hero h1 {
            font-size: 64px;
            line-height: 1.2;
            font-weight: 400;
            margin-bottom: 60px;
            letter-spacing: -1px;
        }

        .hero-arrow {
            width: 50px;
            height: 50px;
            border-right: 2px solid #000;
            border-top: 2px solid #000;
            transform: rotate(-45deg);
            position: absolute;
            right: 60px;
            top: 180px;
        }

        /* Our Work Section */
        .our-work {
            padding: 80px 60px;
            border-top: 1px solid #000000;
        }

        .our-work h2 {
            font-size: 20px;
            font-weight: 400;
            letter-spacing: 0.5px;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .hero-arrow {
                display: none;
            }
        }

        @media (max-width: 768px) {
            header {
                flex-direction: column;
                padding: 20px 30px;
                gap: 30px;
            }

            nav ul {
                flex-direction: column;
                gap: 15px;
            }

            .hero {
                flex-direction: column;
                padding: 50px 30px;
            }

            .hero h1 {
                font-size: 36px;
                margin-bottom: 40px;
            }

            .hero-logo {
                margin-bottom: 40px;
            }

            .our-work {
                padding: 50px 30px;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header>
        <div class="logo">F&F</div>
        <nav>
            <ul>
                <li><a href="#THOUGHTS">Work</a></li>
                <li><a href="#">POST</a></li>
                <li><a href="#ABOUT">Contact</a></li>
            </ul>
        </nav>
    </header>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <!-- F&F Logo with SVG -->
            <div class="hero-logo">
                <svg viewBox="0 0 350 200" xmlns="http://www.w3.org/2000/svg">
                    <!-- Left side: Overlapping circles (O shape) -->
                    <g id="logo-left">
                        <!-- Outer left circle -->
                        <circle cx="60" cy="100" r="55" fill="black"/>
                        <!-- Inner white circle -->
                        <circle cx="60" cy="100" r="35" fill="white"/>
                        <!-- Right overlapping circle outer -->
                        <circle cx="100" cy="100" r="55" fill="black"/>
                        <!-- Right overlapping circle inner white -->
                        <circle cx="100" cy="100" r="35" fill="white"/>
                    </g>

                    <!-- Right side: Circular dots (F shape) -->
                    <g id="logo-right">
                        <!-- Top row -->
                        <circle cx="200" cy="50" r="20" fill="black"/>
                        <circle cx="250" cy="50" r="20" fill="black"/>
                        <circle cx="300" cy="50" r="20" fill="black"/>
                        
                        <!-- Middle row -->
                        <circle cx="175" cy="100" r="20" fill="black"/>
                        <circle cx="225" cy="100" r="20" fill="black"/>
                        <circle cx="275" cy="100" r="20" fill="black"/>
                        <circle cx="325" cy="100" r="20" fill="black"/>
                        
                        <!-- Bottom row -->
                        <circle cx="200" cy="150" r="20" fill="black"/>
                        <circle cx="250" cy="150" r="20" fill="black"/>
                        <circle cx="300" cy="150" r="20" fill="black"/>
                    </g>
                </svg>
            </div>

            <h1>I HAVE A WISH TO MAKE.</h1>
        </div>

        <!-- Arrow on right -->
        <div class="hero-arrow"></div>
    </section>

    <!-- Our Work Section -->
    <section class="our-work" id="work">
        <h2>XXX</h2>
    </section>
</body>
</html>
